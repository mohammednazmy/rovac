<?xml version="1.0"?>
<robot name="rovac_tank">

  <!-- Base Link - Center of robot chassis at motor shaft height (20mm from ground) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.22 0.245 0.10"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
  </link>

  <!-- Front indicator — red wedge showing forward direction (+X) -->
  <link name="front_indicator">
    <visual>
      <geometry>
        <box size="0.06 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="red_front">
        <color rgba="0.9 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <joint name="front_indicator_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_indicator"/>
    <!-- FRONT = LIDAR side = +X per docs/robot_dimensions.md -->
    <origin xyz="0.13 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- Base Footprint (Projected on ground) -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <!-- Motor shaft at 20mm from ground -->
    <origin xyz="0 0 -0.02" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Vacuum Suction Pad ==================== -->
  <!-- Dimensions per measurements (inch->mm):
       width  = 4.125" = 104.775 mm  (Y / lateral)
       depth  = 2.125" =  53.975 mm  (X / fore-aft)
       Rear edge sits 50.8 mm (2") in front of front edge of tracks.
       Front of tracks ~ base_link X = +0.110 m (chassis is 0.22 m long,
       base_link at center). So:
         pad rear edge  = +0.110 + 0.0508    = +0.1608 m  (base_link)
         pad center  X  = +0.1608 + 0.05398/2 = +0.1878 m
       Pad is dead-center laterally (Y=0). Parented to base_footprint so
       Z = 0 is the floor; pad center Z = half pad thickness ≈ 0.0025 m. -->
  <link name="vacuum_pad_link">
    <visual>
      <geometry>
        <box size="0.05398 0.10478 0.005"/>
      </geometry>
      <material name="vacuum_pad">
        <color rgba="0.15 0.15 0.15 0.85"/>
      </material>
    </visual>
  </link>

  <joint name="vacuum_pad_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="vacuum_pad_link"/>
    <origin xyz="0.1878 0 0.0025" rpy="0 0 0"/>
  </joint>

  <!-- ==================== RPLIDAR C1 ==================== -->
  <!-- SLAMTEC RPLIDAR C1 DTOF, 55.6x55.6x41.3mm, scan height 23.1mm from base -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <box size="0.0556 0.0556 0.0413"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <!-- LIDAR scan plane 140mm from ground, 120mm above base_link -->
    <origin xyz="0.015 0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- ==================== IMU ==================== -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- BNO055 mounted face-down on main board, upper edge toward front.
         180° rotation around X flips Z-axis from down (board face) to up (ROS). -->
    <origin xyz="0 0 0.02" rpy="3.14159 0 0"/>
  </joint>

  <!-- Phone IMU + Super Sensor links removed 2026-04-26 — retired hardware
       was producing labels in Foxglove that cluttered the 3D view. The
       BNO055 (imu_link above) replaced the phone IMU; the sensor hub
       (4×HC-SR04 + 2×IR cliff) replaced super_sensor. The actual sensor
       hub mount frames (us_front_link etc.) are publisher-side static TFs
       from rovac_sensor_driver, not URDF — see ros2_ws/src/rovac_sensor_driver. -->

</robot>
