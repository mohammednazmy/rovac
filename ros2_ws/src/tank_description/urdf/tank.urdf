<?xml version="1.0"?>
<robot name="rovac_tank">

  <!-- Base Link - Center of robot chassis at motor shaft height (20mm from ground) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.22 0.245 0.10"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
  </link>

  <!-- Front indicator — red wedge showing forward direction (+X) -->
  <link name="front_indicator">
    <visual>
      <geometry>
        <box size="0.06 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="red_front">
        <color rgba="0.9 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <joint name="front_indicator_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_indicator"/>
    <!-- FRONT = LIDAR side = +X per docs/robot_dimensions.md -->
    <origin xyz="0.13 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- Base Footprint (Projected on ground) -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <!-- Motor shaft at 20mm from ground -->
    <origin xyz="0 0 -0.02" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Vacuum Suction Pad ==================== -->
  <!-- Dimensions per measurements (inch->mm):
       width  = 4.125" = 104.775 mm  (Y / lateral)
       depth  = 2.125" =  53.975 mm  (X / fore-aft)
       Rear edge sits 50.8 mm (2") in front of front edge of tracks.
       Front of tracks ~ base_link X = +0.110 m (chassis is 0.22 m long,
       base_link at center). So:
         pad rear edge  = +0.110 + 0.0508    = +0.1608 m  (base_link)
         pad center  X  = +0.1608 + 0.05398/2 = +0.1878 m
       Pad is dead-center laterally (Y=0). Parented to base_footprint so
       Z = 0 is the floor; pad center Z = half pad thickness ≈ 0.0025 m. -->
  <link name="vacuum_pad_link">
    <visual>
      <geometry>
        <box size="0.05398 0.10478 0.005"/>
      </geometry>
      <material name="vacuum_pad">
        <color rgba="0.15 0.15 0.15 0.85"/>
      </material>
    </visual>
  </link>

  <joint name="vacuum_pad_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="vacuum_pad_link"/>
    <origin xyz="0.1878 0 0.0025" rpy="0 0 0"/>
  </joint>

  <!-- ==================== RPLIDAR C1 ==================== -->
  <!-- SLAMTEC RPLIDAR C1 DTOF, 55.6x55.6x41.3mm, scan height 23.1mm from base -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <box size="0.0556 0.0556 0.0413"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <!-- LIDAR scan plane 140mm from ground, 120mm above base_link -->
    <origin xyz="0.015 0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- ==================== SUPER SENSOR BASE ==================== -->
  <!-- Super Sensor module mounted at front of robot -->
  <link name="super_sensor_link">
    <visual>
      <geometry>
        <box size="0.04 0.08 0.03"/>
      </geometry>
      <material name="green">
        <color rgba="0 0.8 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="super_sensor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="super_sensor_link"/>
    <!-- Mounted at front of robot, ~5cm forward, 3cm up from center -->
    <origin xyz="0.10 0 0.03" rpy="0 0 0"/>
  </joint>

  <!-- ==================== ULTRASONIC SENSORS ==================== -->
  
  <!-- Front Top Ultrasonic (US1) - Points forward and slightly up -->
  <link name="super_sensor_link/front_top_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_front_top_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/front_top_link"/>
    <!-- Top sensor, pointing forward -->
    <origin xyz="0.02 0 0.015" rpy="0 0 0"/>
  </joint>

  <!-- Front Bottom Ultrasonic (US4) - Points forward and slightly down -->
  <link name="super_sensor_link/front_bottom_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_front_bottom_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/front_bottom_link"/>
    <!-- Bottom sensor, pointing forward and slightly down -->
    <origin xyz="0.02 0 -0.015" rpy="0 0.1 0"/>
  </joint>

  <!-- Left Ultrasonic (US2) - Points left -->
  <link name="super_sensor_link/left_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_left_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/left_link"/>
    <!-- Left sensor, pointing left (90 degrees) -->
    <origin xyz="0 0.03 0" rpy="0 0 1.5708"/>
  </joint>

  <!-- Right Ultrasonic (US3) - Points right -->
  <link name="super_sensor_link/right_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_right_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/right_link"/>
    <!-- Right sensor, pointing right (-90 degrees) -->
    <origin xyz="0 -0.03 0" rpy="0 0 -1.5708"/>
  </joint>

  <!-- ==================== IMU ==================== -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- BNO055 mounted face-down on main board, upper edge toward front.
         180° rotation around X flips Z-axis from down (board face) to up (ROS). -->
    <origin xyz="0 0 0.02" rpy="3.14159 0 0"/>
  </joint>

  <!-- ==================== PHONE SENSOR NODE ==================== -->
  <!-- Phone IMU (Samsung Galaxy A16, landscape, screen faces rear) -->
  <link name="phone_imu">
    <visual>
      <geometry>
        <box size="0.164 0.078 0.008"/>
      </geometry>
      <material name="phone_dark">
        <color rgba="0.15 0.15 0.15 1"/>
      </material>
    </visual>
  </link>

  <joint name="phone_imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="phone_imu"/>
    <!-- Calibrated from gravity: roll=90 pitch=-10.7 yaw=90 (phone nearly upright) -->
    <origin xyz="-0.08 0.0 0.234" rpy="1.5708 -0.1868 1.5708"/>
  </joint>

  <!-- Phone GPS frame -->
  <link name="phone_gps"/>

  <joint name="phone_gps_joint" type="fixed">
    <parent link="phone_imu"/>
    <child link="phone_gps"/>
    <!-- GPS antenna at top of phone, ~40mm above phone center -->
    <origin xyz="0 0.04 0" rpy="0 0 0"/>
  </joint>

  <!-- Phone camera frame (rear camera, faces opposite direction of screen) -->
  <link name="phone_camera"/>

  <joint name="phone_camera_joint" type="fixed">
    <parent link="phone_imu"/>
    <child link="phone_camera"/>
    <!-- Rear camera at top-left corner of phone back, optical axis = -Z of phone -->
    <origin xyz="0 0.07 -0.004" rpy="0 0 0"/>
  </joint>

</robot>
