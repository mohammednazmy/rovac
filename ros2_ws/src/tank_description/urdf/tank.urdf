<?xml version="1.0"?>
<robot name="rovac_tank">

  <!-- Base Link - Center of robot chassis at motor shaft height (20mm from ground) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.22 0.245 0.10"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
  </link>

  <!-- Base Footprint (Projected on ground) -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <!-- Motor shaft at 20mm from ground -->
    <origin xyz="0 0 -0.02" rpy="0 0 0"/>
  </joint>

  <!-- ==================== XV-11 LIDAR ==================== -->
  <!-- Mounted on top of robot, pointing forward -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <!-- LIDAR scan plane 152.5mm from ground, 132.5mm above base_link -->
    <origin xyz="0.015 0 0.1325" rpy="0 0 0"/>
  </joint>

  <!-- ==================== SUPER SENSOR BASE ==================== -->
  <!-- Super Sensor module mounted at front of robot -->
  <link name="super_sensor_link">
    <visual>
      <geometry>
        <box size="0.04 0.08 0.03"/>
      </geometry>
      <material name="green">
        <color rgba="0 0.8 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="super_sensor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="super_sensor_link"/>
    <!-- Mounted at front of robot, ~5cm forward, 3cm up from center -->
    <origin xyz="0.10 0 0.03" rpy="0 0 0"/>
  </joint>

  <!-- ==================== ULTRASONIC SENSORS ==================== -->
  
  <!-- Front Top Ultrasonic (US1) - Points forward and slightly up -->
  <link name="super_sensor_link/front_top_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_front_top_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/front_top_link"/>
    <!-- Top sensor, pointing forward -->
    <origin xyz="0.02 0 0.015" rpy="0 0 0"/>
  </joint>

  <!-- Front Bottom Ultrasonic (US4) - Points forward and slightly down -->
  <link name="super_sensor_link/front_bottom_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_front_bottom_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/front_bottom_link"/>
    <!-- Bottom sensor, pointing forward and slightly down -->
    <origin xyz="0.02 0 -0.015" rpy="0 0.1 0"/>
  </joint>

  <!-- Left Ultrasonic (US2) - Points left -->
  <link name="super_sensor_link/left_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_left_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/left_link"/>
    <!-- Left sensor, pointing left (90 degrees) -->
    <origin xyz="0 0.03 0" rpy="0 0 1.5708"/>
  </joint>

  <!-- Right Ultrasonic (US3) - Points right -->
  <link name="super_sensor_link/right_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_right_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/right_link"/>
    <!-- Right sensor, pointing right (-90 degrees) -->
    <origin xyz="0 -0.03 0" rpy="0 0 -1.5708"/>
  </joint>

  <!-- ==================== IMU ==================== -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- IMU mounted on main board, centered -->
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <!-- ==================== PHONE SENSOR NODE ==================== -->
  <!-- Phone IMU (Samsung Galaxy A16, landscape, screen faces rear) -->
  <link name="phone_imu">
    <visual>
      <geometry>
        <box size="0.164 0.078 0.008"/>
      </geometry>
      <material name="phone_dark">
        <color rgba="0.15 0.15 0.15 1"/>
      </material>
    </visual>
  </link>

  <joint name="phone_imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="phone_imu"/>
    <!-- Calibrated from gravity: roll=90 pitch=-10.7 yaw=90 (phone nearly upright) -->
    <origin xyz="-0.08 0.0 0.234" rpy="1.5708 -0.1868 1.5708"/>
  </joint>

  <!-- Phone GPS frame -->
  <link name="phone_gps"/>

  <joint name="phone_gps_joint" type="fixed">
    <parent link="phone_imu"/>
    <child link="phone_gps"/>
    <!-- GPS antenna at top of phone, ~40mm above phone center -->
    <origin xyz="0 0.04 0" rpy="0 0 0"/>
  </joint>

  <!-- Phone camera frame (rear camera, faces opposite direction of screen) -->
  <link name="phone_camera"/>

  <joint name="phone_camera_joint" type="fixed">
    <parent link="phone_imu"/>
    <child link="phone_camera"/>
    <!-- Rear camera at top-left corner of phone back, optical axis = -Z of phone -->
    <origin xyz="0 0.07 -0.004" rpy="0 0 0"/>
  </joint>

</robot>
