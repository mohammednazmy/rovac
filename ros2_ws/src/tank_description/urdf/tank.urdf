<?xml version="1.0"?>
<robot name="rovac_tank">

  <!-- Base Link - Center of robot chassis -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.25 0.20 0.10"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
  </link>

  <!-- Base Footprint (Projected on ground) -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>

  <!-- ==================== XV-11 LIDAR ==================== -->
  <!-- Mounted on top of robot, pointing forward -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <!-- LIDAR positioned on top of robot, ~12.5cm above base_link center -->
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
  </joint>

  <!-- ==================== SUPER SENSOR BASE ==================== -->
  <!-- Super Sensor module mounted at front of robot -->
  <link name="super_sensor_link">
    <visual>
      <geometry>
        <box size="0.04 0.08 0.03"/>
      </geometry>
      <material name="green">
        <color rgba="0 0.8 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="super_sensor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="super_sensor_link"/>
    <!-- Mounted at front of robot, ~5cm forward, 3cm up from center -->
    <origin xyz="0.10 0 0.03" rpy="0 0 0"/>
  </joint>

  <!-- ==================== ULTRASONIC SENSORS ==================== -->
  
  <!-- Front Top Ultrasonic (US1) - Points forward and slightly up -->
  <link name="super_sensor_link/front_top_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_front_top_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/front_top_link"/>
    <!-- Top sensor, pointing forward -->
    <origin xyz="0.02 0 0.015" rpy="0 0 0"/>
  </joint>

  <!-- Front Bottom Ultrasonic (US4) - Points forward and slightly down -->
  <link name="super_sensor_link/front_bottom_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_front_bottom_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/front_bottom_link"/>
    <!-- Bottom sensor, pointing forward and slightly down -->
    <origin xyz="0.02 0 -0.015" rpy="0 0.1 0"/>
  </joint>

  <!-- Left Ultrasonic (US2) - Points left -->
  <link name="super_sensor_link/left_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_left_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/left_link"/>
    <!-- Left sensor, pointing left (90 degrees) -->
    <origin xyz="0 0.03 0" rpy="0 0 1.5708"/>
  </joint>

  <!-- Right Ultrasonic (US3) - Points right -->
  <link name="super_sensor_link/right_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="us_right_joint" type="fixed">
    <parent link="super_sensor_link"/>
    <child link="super_sensor_link/right_link"/>
    <!-- Right sensor, pointing right (-90 degrees) -->
    <origin xyz="0 -0.03 0" rpy="0 0 -1.5708"/>
  </joint>

  <!-- ==================== IMU ==================== -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- IMU mounted on main board, centered -->
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CAMERA (Phone) ==================== -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.08 0.04 0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- Camera phone mounted on servo arm at front -->
    <origin xyz="0.08 0 0.10" rpy="0 0 0"/>
  </joint>


  <!-- ==================== STEREO CAMERA ==================== -->
  <link name="stereo_camera">
    <visual>
      <geometry>
        <box size="0.15 0.03 0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
  </link>

  <joint name="stereo_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="stereo_camera"/>
    <!-- Stereo cameras mounted at front top of robot, ~10cm baseline -->
    <origin xyz="0.10 0 0.12" rpy="0 0 0"/>
  </joint>

</robot>
