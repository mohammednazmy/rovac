#!/usr/bin/env python3
"""
cmd_vel Multiplexer - FIXED version
Always forwards joystick commands when they arrive.
"""

import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist


class CmdVelMux(Node):
    def __init__(self):
        super().__init__("cmd_vel_mux")

        self.cmd_pub = self.create_publisher(Twist, "cmd_vel", 10)
        
        self.nav_sub = self.create_subscription(
            Twist, "cmd_vel_smoothed", self.nav_callback, 10)
        self.joy_sub = self.create_subscription(
            Twist, "cmd_vel_joy", self.joy_callback, 10)

        # Timeout: after this duration without joy input, use nav commands
        self.joy_timeout = 1.0  # seconds
        self.last_joy_time = self.get_clock().now()
        
        self.last_nav_cmd = Twist()
        self.last_joy_cmd = Twist()

        # Publish at 20Hz
        self.timer = self.create_timer(0.05, self.publish_cmd)
        
        self.get_logger().info("cmd_vel_mux FIXED ready")

    def nav_callback(self, msg):
        self.last_nav_cmd = msg

    def joy_callback(self, msg):
        self.last_joy_cmd = msg
        self.last_joy_time = self.get_clock().now()
        # Immediately publish joy command for responsiveness
        self.cmd_pub.publish(msg)

    def publish_cmd(self):
        now = self.get_clock().now()
        elapsed = (now - self.last_joy_time).nanoseconds / 1e9

        # If joy input within timeout, publish last joy command
        # Otherwise publish nav command
        if elapsed < self.joy_timeout:
            self.cmd_pub.publish(self.last_joy_cmd)
        else:
            self.cmd_pub.publish(self.last_nav_cmd)


def main(args=None):
    rclpy.init(args=args)
    node = CmdVelMux()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
