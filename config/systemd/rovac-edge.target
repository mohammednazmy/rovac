[Unit]
Description=ROVAC Edge Stack (Pi 5 Sensors and Motors)
Documentation=https://github.com/mohammednazmy/rovac
After=network-online.target
Wants=network-online.target

# Motor driver (USB serial COBS binary protocol to ESP32)
Wants=rovac-edge-motor-driver.service

# Sensor hub (USB serial COBS binary — 4x ultrasonic + 2x cliff)
Wants=rovac-edge-sensor-hub.service

# RPLIDAR C1 (USB serial, native ROS2 driver)
Wants=rovac-edge-rplidar-c1.service

# Core services
Wants=rovac-edge-mux.service
Wants=rovac-edge-tf.service
Wants=rovac-edge-map-tf.service
Wants=rovac-edge-obstacle.service
Wants=rovac-edge-health.service

# PS2 wireless controller (joy_node + mapper on Pi)
Wants=rovac-edge-ps2-joy.service
Wants=rovac-edge-ps2-mapper.service

[Install]
WantedBy=multi-user.target
