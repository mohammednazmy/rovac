<?xml version="1.0" encoding="UTF-8"?>
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <Interfaces>
        <!-- Use en0 (WiFi) for home network communication -->
        <NetworkInterface address="192.168.1.104" priority="default" multicast="false"/>
      </Interfaces>
    </General>
    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <Peers>
        <!-- Local Mac participants -->
        <Peer address="192.168.1.104"/>
        <!-- Pi -->
        <Peer address="192.168.1.200"/>
      </Peers>
    </Discovery>
    <Tracing>
      <Verbosity>warning</Verbosity>
    </Tracing>
  </Domain>
</CycloneDDS>
