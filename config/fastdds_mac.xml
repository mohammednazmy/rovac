<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <transport_descriptors>
      <!-- Shared Memory Transport (Localhost High Speed) -->
      <transport_descriptor>
        <transport_id>shm_transport</transport_id>
        <type>SHM</type>
      </transport_descriptor>

      <!-- UDP Transport (Robot Network + Loopback) -->
      <transport_descriptor>
        <transport_id>udp_transport</transport_id>
        <type>UDPv4</type>
        <interfaceWhiteList>
          <address>192.168.1.104</address>
          <address>127.0.0.1</address>
        </interfaceWhiteList>
      </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="participant_profile" is_default_profile="true">
      <rtps>
        <!-- Use Custom Transports -->
        <useBuiltinTransports>false</useBuiltinTransports>
        <userTransports>
          <transport_id>shm_transport</transport_id>
          <transport_id>udp_transport</transport_id>
        </userTransports>

        <!-- Discovery Settings -->
        <builtin>
          <discovery_config>
            <discoveryProtocol>SIMPLE</discoveryProtocol>
          </discovery_config>
          
          <!-- Standard Multicast Discovery REMOVED to force Unicast -->
          <!-- <metatrafficMulticastLocatorList> ... </metatrafficMulticastLocatorList> -->

          <!-- Initial Peer (The Pi) -->
          <initialPeersList>
            <locator>
              <udpv4>
                <address>192.168.1.200</address>
                <port>17900</port>
              </udpv4>
            </locator>
          </initialPeersList>
        </builtin>
        
        <!-- Default Unicast Locators (Where others find ME) -->
        <defaultUnicastLocatorList>
          <locator>
            <udpv4>
              <address>192.168.1.104</address>
            </udpv4>
          </locator>
          <locator>
             <udpv4>
               <address>127.0.0.1</address>
             </udpv4>
          </locator>
        </defaultUnicastLocatorList>
      </rtps>
    </participant>
  </profiles>
</dds>
