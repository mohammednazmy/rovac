# ROVAC ESP32-S3 AT8236 Motor Controller — Espressif USB-CDC
# Creates /dev/esp32_motor symlink when the ESP32-S3 native USB is connected.
# TAG+="systemd" enables device-based service activation (BindsTo=).
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", SYMLINK+="esp32_motor", MODE="0666", TAG+="systemd"

# RPLIDAR C1 — Silicon Labs CP2102N USB-UART bridge
# Creates /dev/rplidar_c1 symlink. Serial number uniquely identifies this unit.
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="2cc40fe2db73ef1185f9cd8c8fcc3fa0", SYMLINK+="rplidar_c1", MODE="0666"
