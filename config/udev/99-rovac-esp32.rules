# ROVAC USB Device Rules — Raspberry Pi 5
# Updated: 2026-03-21

# Maker-ESP32 Motor Controller (CH340, 1a86:7523) — any USB port
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", SYMLINK+="esp32_motor", MODE="0666", TAG+="systemd"

# RPLIDAR C1 (CP2102N, serial 2cc40fe2db73ef1185f9cd8c8fcc3fa0) — SLAMTEC 360° DTOF LIDAR
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="2cc40fe2db73ef1185f9cd8c8fcc3fa0", SYMLINK+="rplidar_c1", MODE="0666"
