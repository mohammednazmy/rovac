            "direction": "row",
            "splitPercentage": 50
          },
          "direction": "row",
          "splitPercentage": 50
        },
        "direction": "row",
        "splitPercentage": 25
      },
      "second": {
        "first": "RawMessages!odom",
        "second": "RawMessages!imu",
        "direction": "row",
        "splitPercentage": 50
      },
      "direction": "column",
