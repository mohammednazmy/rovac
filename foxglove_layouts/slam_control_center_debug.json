    },
    "Indicator!camera_status": {
      "path": "/image_raw/compressed.header.stamp.sec",
      "style": "background",
      "fallbackColor": "#880000",
      "fallbackLabel": "CAMERA OFFLINE",
      "rules": [
        {
          "operator": ">",
          "rawValue": "0",
          "color": "#00aa00",
          "label": "CAMERA OK"
