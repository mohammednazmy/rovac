      ]
    },
    "Publish!save_map": {
      "topicName": "/map_save_cmd",
      "datatype": "std_msgs/msg/String",
      "value": "{ \"data\": \"house_map\" }"
    },
    "RawMessages!pose_view": {
      "topicPath": "/odom",
      "diffEnabled": false,
      "expansion": "first"
    }
  },
  "globalVariables": {},
  "userNodes": {},
  "playbackConfig": {
    "speed": 1
  },
  "layout": {
    "direction": "column",
    "splitPercentage": 60,
    "first": {
      "direction": "row",
      "splitPercentage": 60,
      "first": "3D!slam_view",
      "second": {
        "direction": "column",
        "splitPercentage": 50,
        "first": "Image!webcam",
        "second": "Plot!vel_plot"
      }
    },
    "second": {
      "direction": "row",
      "splitPercentage": 50,
      "first": {
        "direction": "column",
        "splitPercentage": 50,
        "first": "RawMessages!tf_view",
        "second": "RawMessages!tf_static_view"
      },
      "second": {
        "direction": "column",
        "splitPercentage": 50,
        "first": "RawMessages!scan_view",
        "second": "RawMessages!diagnostics_raw"
      }
    }
  }
}
